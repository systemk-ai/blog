---
import type { CollectionEntry } from "astro:content";
import ArticleRow from "./ArticleRow.astro";
import Icon from "./Icon.astro";

interface Props {
	items: CollectionEntry<"blog">[];
	eyebrow: string;
	title: string;
	// Optional: when omitted, no description line is rendered.
	intro?: string;
}
const { items, eyebrow, title, intro } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="border-b border-line-subtle">
	<div class="mx-auto max-w-[1080px] px-8 pt-12 pb-9">
		<a
			href={base}
			class="mb-4 inline-flex items-center gap-1.5 text-[13px] text-muted no-underline"
		>
			<Icon name="arrow-left" size={14} /> ホームへ
		</a>
		<div class="sk-eyebrow mb-3">{eyebrow}</div>
		<h1 class="mb-2.5 font-serif text-3xl tracking-tight text-strong">{title}</h1>
		{
			intro && (
				<p class="mb-1.5 max-w-[560px] font-serif text-md leading-[1.8] text-body">
					{intro}
				</p>
			)
		}
		<div class="font-mono text-xs text-muted">{items.length} 件</div>
	</div>
</section>
<div class="mx-auto max-w-[1080px] px-8 pt-4 [&>*:first-child]:border-t-0">
	{
		items.length > 0 ? (
			items.map((post) => <ArticleRow post={post} />)
		) : (
			<p class="py-10 text-center text-sm text-muted">記事はまだありません。</p>
		)
	}
</div>
