---
// Content-type pill: research → "Paper" (slate-blue), case → "Case" (sage).
interface Props {
	type: "research" | "case";
	class?: string;
}
const { type, class: cls } = Astro.props;
const map = {
	research: { label: "Paper", cls: "bg-blue-50 text-primary-active" },
	case: { label: "Case", cls: "bg-sage-100 text-sage-700" },
} as const;
const { label, cls: tone } = map[type];
---

<span
	class:list={[
		"inline-flex items-center rounded-full border border-transparent px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-[0.06em]",
		tone,
		cls,
	]}>{label}</span
>
