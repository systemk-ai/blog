---
import Icon from "./Icon.astro";

const base = import.meta.env.BASE_URL;
const year = 2002;
---

<footer class="mt-[72px] border-t border-line-subtle bg-paper-warm font-sans">
	<div
		class="mx-auto flex max-w-[1080px] flex-wrap justify-between gap-10 px-8 py-11"
	>
		<div class="max-w-[300px]">
			<div class="mb-3 inline-flex items-baseline gap-1.5">
				<span class="text-base font-bold italic tracking-tight text-strong"
					>SystemK</span
				>
				<span class="text-base font-semibold text-primary">AI</span>
			</div>
			<p class="mb-4 text-xs leading-[1.75] text-muted">
				株式会社システムケイ AI研究開発部門。視覚AIと生成AIの研究開発、および実応用の記録。
			</p>
			<a
				href={`${base}rss.xml`}
				class="inline-flex items-center gap-1.5 text-xs text-ochre-700 no-underline"
			>
				<Icon name="rss" size={13} /> RSS フィード
			</a>
		</div>
		<div class="flex flex-wrap gap-14 text-[13px]">
			<div class="flex flex-col gap-2.5">
				<span class="sk-eyebrow text-[11px]">コンテンツ</span>
				<a
					href={`${base}research/`}
					class="text-muted no-underline hover:text-strong">研究・論文</a
				>
				<a
					href={`${base}cases/`}
					class="text-muted no-underline hover:text-strong">導入事例</a
				>
			</div>
			<div class="flex flex-col gap-2.5">
				<span class="sk-eyebrow text-[11px]">リソース</span>
				<a
					href="https://github.com/systemk-ai/blog"
					class="inline-flex items-center gap-1.5 text-muted no-underline hover:text-strong"
				>
					<Icon name="github" size={13} /> GitHub
				</a>
				<a
					href="https://www.systemk.co.jp/"
					class="text-muted no-underline hover:text-strong">システム・ケイ</a
				>
			</div>
		</div>
	</div>
	<div class="border-t border-line-faint">
		<div
			class="mx-auto flex max-w-[1080px] flex-wrap justify-between gap-4 px-8 py-4 text-[11px] text-faint"
		>
			<span>© {year} System K Corp. All Rights Reserved.</span>
			<a
				href="https://www.systemk.co.jp/"
				class="text-faint no-underline hover:text-strong">株式会社システム・ケイ</a
			>
		</div>
	</div>
</footer>
