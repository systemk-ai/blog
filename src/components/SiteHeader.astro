---
import Icon from "./Icon.astro";
import SearchBox from "./SearchBox.astro";

interface Props {
	active?: "home" | "research" | "cases";
}
const { active = "home" } = Astro.props;
const base = import.meta.env.BASE_URL;
const nav = [
	{ id: "home", label: "ホーム", href: base },
	{ id: "research", label: "研究・論文", href: `${base}research/` },
	{ id: "cases", label: "導入事例", href: `${base}cases/` },
];
---

<header
	class="sticky top-0 z-40 border-b border-line-subtle bg-paper/85 font-sans backdrop-blur-md"
>
	<div class="mx-auto flex h-[62px] max-w-[1080px] items-center gap-7 px-8">
		<a href={base} class="flex flex-none items-baseline gap-1.5 no-underline">
			<span class="text-[17px] font-bold italic tracking-tight text-strong"
				>SystemK</span
			>
			<span class="text-[17px] font-semibold text-primary">AI</span>
		</a>
		<nav class="flex gap-0.5">
			{
				nav.map((n) => (
					<a
						href={n.href}
						class:list={[
							"rounded-sm px-3 py-1.5 text-[13px] no-underline transition-colors",
							active === n.id
								? "font-semibold text-strong"
								: "font-medium text-muted hover:text-strong",
						]}
					>
						{n.label}
					</a>
				))
			}
		</nav>
		<div class="ml-auto flex items-center gap-3">
			<SearchBox />
			<a
				href={`${base}rss.xml`}
				title="RSS フィード"
				aria-label="RSS フィード"
				class="flex h-[34px] w-[34px] items-center justify-center rounded-sm border border-line-subtle text-ochre-700 no-underline"
			>
				<Icon name="rss" size={16} />
			</a>
		</div>
	</div>
</header>
