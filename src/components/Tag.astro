---
// Tag pill linking to its tag page. Base-aware.
interface Props {
	name: string;
	class?: string;
}
const { name, class: cls } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a
	href={`${base}tags/${encodeURIComponent(name)}/`}
	class:list={[
		"inline-flex items-center rounded-full border border-line-subtle bg-paper px-2.5 py-0.5 text-[11px] text-muted no-underline transition-colors hover:text-strong",
		cls,
	]}>#{name}</a
>
