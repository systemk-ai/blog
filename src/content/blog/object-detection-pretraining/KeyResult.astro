---
// One-off component, co-located with this article (per AGENTS.md §Content structure:
// single-use components live in the article folder, not src/components).
interface Props {
	value: string;
	label: string;
	note?: string;
}
const { value, label, note } = Astro.props;
---

<div
	class="flex items-baseline gap-4 rounded-md border border-line-subtle bg-paper-warm px-5 py-4"
>
	<div class="font-mono text-3xl font-semibold text-primary">{value}</div>
	<div>
		<div class="text-sm font-medium text-strong">{label}</div>
		{note && <div class="mt-0.5 text-xs text-muted">{note}</div>}
	</div>
</div>
