---
import { getCollection } from "astro:content";
import PostMeta from "../components/PostMeta.astro";
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

// Drafts are excluded from the list, but still reachable by direct URL
// (see src/pages/[...slug].astro, which builds a page for every entry).
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog" description="A minimal static blog built with Astro.">
	<main>
		<h1>Blog</h1>
		<ul>
			{
				posts.map((post) => (
					<li>
						<a href={`${base}${post.id}/`}>{post.data.title}</a>
						<PostMeta pubDate={post.data.pubDate} tags={post.data.tags} />
					</li>
				))
			}
		</ul>
	</main>
</Layout>
